                                <div className="absolute inset-0 bg-gradient-to-t from-granate to-transparent" />
                                <button onClick={() => setSelected(null)} className="absolute top-10 left-6 p-4 bg-black/50 backdrop-blur-md rounded-full">
                                    <Icon name="X" size={24} />
                                </button>
                            </div>
                            <div className="px-8 -mt-10 relative space-y-6">
                                <span className="bg-violeta px-4 py-1 rounded-full text-[10px] font-tritono uppercase shadow-violet">{selected.category}</span>
                                <h2 className="text-5xl font-tritono italic uppercase leading-none tracking-tighter">{selected.title}</h2>
