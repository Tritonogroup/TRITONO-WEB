                            { id: 'perfil', icon: 'User' }
                        ].map(t => (
                            <button key={t.id} onClick={() => setActiveTab(t.id)} className={`p-4 transition-all ${activeTab === t.id ? 'text-amarillo scale-125' : 'text-white/20'}`}>
