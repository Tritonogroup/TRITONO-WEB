                            </div>
                        )}
                        
                        {activeTab === 'perfil' && (
                            <div className="p-8 space-y-10 text-center">
                                <div className="w-32 h-32 rounded-full border-4 border-amarillo mx-auto overflow-hidden shadow-2xl">
                                    <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=tritono" alt="" />
                                </div>
                                <h2 className="text-4xl font-tritono italic uppercase">Usuario_GRX</h2>
                                <div className="grid grid-cols-2 gap-4">
                                    <div className="bg-white/5 p-6 rounded-3xl border border-white/5">
                                        <p className="text-2xl font-tritono italic">12</p>
                                        <p className="text-[8px] font-tritono text-white/40 uppercase">Eventos</p>
                                    </div>
                                    <div className="bg-white/5 p-6 rounded-3xl border border-white/5">
                                        <p className="text-2xl font-tritono italic text-amarillo">Vip</p>
                                        <p className="text-[8px] font-tritono text-white/40 uppercase">Estado</p>
                                    </div>
                                </div>
                            </div>
